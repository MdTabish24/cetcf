# ==============================================
# CETCF BACKEND — PRODUCTION ENV TEMPLATE
# ==============================================

# ---- Server ----
PORT=5000
NODE_ENV=production
TRUST_PROXY=true
# Keep false for quick/partial deploys. Set true after all production vars are configured.
STRICT_ENV_VALIDATION=false

# ---- Database (PostgreSQL) ----
DB_HOST=YOUR_DB_HOST
DB_PORT=5432
DB_NAME=YOUR_DB_NAME
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD

# ---- JWT ----
JWT_SECRET=GENERATE_A_RANDOM_32_PLUS_CHAR_SECRET
JWT_EXPIRES_IN=30d

# ---- MSG91 (SMS/OTP) ----
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY
MSG91_TEMPLATE_ID=YOUR_MSG91_TEMPLATE_ID
MSG91_SENDER_ID=CETCFN

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET=YOUR_CERTIFICATE_BUCKET

# ---- SendGrid (Email) ----
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ---- WhatsApp (Optional but recommended) ----
WHATSAPP_API_KEY=YOUR_WHATSAPP_API_KEY
WHATSAPP_API_URL=https://api.interakt.ai/v1/public/message/

# ---- Admin Bootstrap ----
ADMIN_INITIAL_EMAIL=admin@yourdomain.com
ADMIN_INITIAL_PASSWORD=SET_STRONG_TEMP_PASSWORD

# ---- Frontend / Public URLs ----
CERT_BASE_URL=https://verify.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com

# ---- Security ----
DEV_MODE=false
