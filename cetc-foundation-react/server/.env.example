# ==============================================
# CETCF BACKEND — ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env and fill in your values

# ---- Server ----
PORT=5000
NODE_ENV=production
TRUST_PROXY=true

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cetcf_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=30d

# ---- MSG91 (SMS/OTP) ----
# Get from https://msg91.com
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=CETCFN

# ---- Razorpay ----
# Get from https://razorpay.com/dashboard
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ---- AWS S3 ----
# Get from https://aws.amazon.com/s3/
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=cetcf-certificates

# ---- SendGrid (Email) ----
# Get from https://sendgrid.com
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@cetcfoundation.org

# ---- WhatsApp (Interakt/Wati) ----
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_API_URL=https://api.interakt.ai/v1/public/message/

# ---- Admin (Initial Admin Credentials) ----
ADMIN_INITIAL_EMAIL=admin@cetcfoundation.org
ADMIN_INITIAL_PASSWORD=Admin@CETCF2025

# ---- Certificate ----
# Public URL where certificates are accessible
CERT_BASE_URL=https://verify.cetcfoundation.org
FRONTEND_URL=https://app.cetcfoundation.org

# ---- Dev Mode ----
# When true: OTPs are returned in API response (never use in production!)
DEV_MODE=false
